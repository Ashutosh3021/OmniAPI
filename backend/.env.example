# FastAPI Configuration
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=info
API_TITLE=OmniAPI
API_VERSION=1.0.0

# Supabase (optional metadata — app uses DATABASE_URL for SQLAlchemy)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Database — copy URI from Supabase: Settings → Database → Connection string
# App runtime: use "Session pooler" (port 6543). Migrations: use "Direct" (port 5432).
# URL-encode special characters in the password.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DB_ECHO=False

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=generate-with-python-cryptography-fernet-generate-key
CELERY_TASK_TIMEOUT=10
RATE_LIMIT_FREE=100
RATE_LIMIT_PRO=1000
RATE_LIMIT_ENTERPRISE=10000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
