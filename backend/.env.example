# OmniAPI Backend - Environment Variables Template
# Copy this file to .env.local for development or set in production deployment platform

# ================================
# Application Configuration
# ================================
ENVIRONMENT=development  # Options: development, staging, production
DEBUG=False              # NEVER set True in production
LOG_LEVEL=info          # Options: debug, info, warning, error, critical
API_TITLE=OmniAPI
API_VERSION=1.0.0

# ================================
# Database Configuration (Supabase PostgreSQL)
# ================================
# Get from: Supabase → Settings → Database → Connection string
# For app runtime: use "Session pooler" connection (port 6543)
# For migrations: use "Direct connection" (port 5432)
# IMPORTANT: URL-encode special characters in password (@ = %40, # = %23, etc.)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Optional: Direct connection for migrations (if needed)
# DATABASE_URL_DIRECT=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

DB_ECHO=False  # Set True for SQL query logging (dev only)

# ================================
# Redis Configuration
# ================================
# Development: redis://localhost:6379/0
# Production options:
#   - AWS ElastiCache: redis://your-cluster.cache.amazonaws.com:6379/0
#   - Redis Cloud: redis://default:password@endpoint.cloud.redislabs.com:12345
#   - Upstash: redis://default:token@endpoint.upstash.io:6379
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ================================
# Security & Authentication
# ================================
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE-THIS-IN-PRODUCTION-USE-SECURE-RANDOM-KEY

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Generate ENCRYPTION_KEY with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Used to encrypt external API keys in database
ENCRYPTION_KEY=CHANGE-THIS-IN-PRODUCTION-USE-FERNET-KEY

# ================================
# Rate Limiting (requests per hour)
# ================================
RATE_LIMIT_FREE=100
RATE_LIMIT_PRO=1000
RATE_LIMIT_ENTERPRISE=10000

# ================================
# Celery Configuration
# ================================
CELERY_TASK_TIMEOUT=10  # seconds

# ================================
# CORS Configuration
# ================================
# Development: http://localhost:3000
# Production: https://your-frontend-domain.com
# Multiple origins: separate with commas (no spaces)
ALLOWED_ORIGINS=http://localhost:3000

# ================================
# Optional: Supabase Metadata
# ================================
# These are informational only - app uses DATABASE_URL for connections
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_DB_PASSWORD=your_database_password
