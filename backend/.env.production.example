# OmniAPI Backend - Production Environment Template
# DO NOT commit this file with real values - use secrets manager in production

# Application
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=warning
API_TITLE=OmniAPI
API_VERSION=1.0.0

# Database (Supabase Session Pooler)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DB_ECHO=False

# Redis (Use managed Redis service)
REDIS_URL=redis://your-production-redis-endpoint:6379/0

# Security (Generate new keys - DO NOT reuse development keys)
SECRET_KEY=<generate-new-with-secrets.token_urlsafe>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=<generate-new-with-Fernet.generate_key>

# Rate Limiting
RATE_LIMIT_FREE=100
RATE_LIMIT_PRO=1000
RATE_LIMIT_ENTERPRISE=10000

# Celery
CELERY_TASK_TIMEOUT=30

# CORS (Your production frontend URL)
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Supabase (optional metadata)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_DB_PASSWORD=your_database_password
